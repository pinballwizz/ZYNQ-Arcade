#!/bin/sh

ADDR=0x43C00000

RAW=$(devmem $ADDR 8)

# Mask to lower 5 bits
VALUE=$(( RAW & 0x1F ))

echo "Detected 5-bit value: $VALUE"

case $VALUE in
    0)
        BITFILE="game_00"
        ;;
    1)
        BITFILE="game_01"
        ;;
    2)
        BITFILE="game_02"
        ;;
    3)
        BITFILE="game_03"
        ;;
    4)
        BITFILE="game_04"
        ;;
    5)
        BITFILE="game_05"
        ;;
    6)
        BITFILE="game_06"
        ;;
    7)
        BITFILE="game_07"
        ;;
    8)
        BITFILE="game_08"
        ;;
    9)
        BITFILE="game_09"
        ;;
    10)
        BITFILE="game_10"
        ;;
    11)
        BITFILE="game_11"
        ;;
    12)
        BITFILE="game_12"
        ;;
    13)
        BITFILE="game_13"
        ;;
    14)
        BITFILE="game_14"
        ;;
    15)
        BITFILE="game_15"
        ;;
    16)
        BITFILE="game_16"
        ;;
    17)
        BITFILE="game_17"
        ;;
    18)
        BITFILE="game_18"
        ;;
    19)
        BITFILE="game_19"
        ;;
    20)
        BITFILE="game_20"
        ;;
    21)
        BITFILE="game_21"
        ;;
    22)
        BITFILE="game_22"
        ;;
    23)
        BITFILE="game_23"
        ;;
    24)
        BITFILE="game_24"
        ;;
    25)
        BITFILE="game_25"
        ;;
    26)
        BITFILE="game_26"
        ;;
    27)
        BITFILE="game_27"
        ;;
    28)
        BITFILE="game_28"
        ;;
    29)
        BITFILE="game_29"
        ;;
    30)
        BITFILE="game_30"
        ;;
    31)
        BITFILE="game_31"
        ;;
    *)
        echo "No Game assigned for value $VALUE"
        exit 1
        ;;
esac

echo "Loading Game: $BITFILE"

cat /mnt/sdcard/"$BITFILE"/* > /dev/xdevcfg

if [ $? -eq 0 ]; then
    echo "Game programmed successfully."
else
    echo "Game programming failed."
fi



